{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./build.mjs && cross-env NODE_ENV=development node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "build:railway": "pnpm --dir ../.. --filter @workspace/aleryaf-hub run build && pnpm run build",
    "start": "cross-env NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "start:local": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cross-env NODE_ENV=test DATABASE_URL=postgresql://test:test@127.0.0.1:5432/test SESSION_SECRET=test-session-secret-1234567890abcdef VAPID_PUBLIC_KEY=test-public-vapid-key VAPID_PRIVATE_KEY=test-private-vapid-key VAPID_SUBJECT=mailto:test@example.com pnpm exec tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "helmet": "^8.1.0",
    "pino": "^9",
    "pino-http": "^10",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.1.4",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
